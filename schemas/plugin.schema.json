{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/DEFRA/defra-ai-plugins/blob/main/schemas/plugin.schema.json",
  "title": "Defra plugin manifest",
  "description": "Schema for plugins/<plugin-name>/plugin.json — the manifest for a single Copilot CLI plugin.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description", "version", "author", "license"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "description": "Plugin identifier in kebab-case. Must match the directory name."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Brief description of what the plugin does."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$",
      "description": "Semantic version."
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "SPDX licence identifier. Defra plugins should use 'OGL-UK-3.0' unless an exception applies."
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "category": {
      "type": "string",
      "enum": [
        "development",
        "testing",
        "accessibility",
        "security",
        "documentation",
        "productivity",
        "data"
      ]
    },
    "keywords": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 30
      }
    }
  }
}
